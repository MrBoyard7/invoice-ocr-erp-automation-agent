# ---------------------------------------------------------------------------
# Environment variables for invoice-ocr-erp-automation-agent
# Copy this file to ".env" and fill in real values. Never commit the ".env"
# file: it is already excluded via .gitignore.
# ---------------------------------------------------------------------------

# --- Email ingestion (IMAP) -------------------------------------------------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=invoices@example.com
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true

# --- Scanner ingestion -------------------------------------------------------
SCANNER_WATCH_FOLDER=./data/incoming_scans
SCANNER_PROCESSED_FOLDER=./data/processed_scans

# --- OCR (Parseur) ------------------------------------------------------------
PARSEUR_API_KEY=change-me
PARSEUR_MAILBOX_ID=change-me
PARSEUR_BASE_URL=https://api.parseur.com

# --- Automation (Zapier) -------------------------------------------------------
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx/

# --- SADE ERP (SQL database) ---------------------------------------------------
# Any SQLAlchemy-compatible connection string can be used, for example:
#   sqlite:///./demo.db
#   postgresql+psycopg2://user:password@host:5432/sade
#   mssql+pyodbc://user:password@host/sade?driver=ODBC+Driver+17+for+SQL+Server
SADE_DATABASE_URL=sqlite:///./demo.db

# --- General -------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
